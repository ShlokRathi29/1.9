# Copy this file to .env and fill in your values

# ─── DB1 (Our PostgreSQL) ────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/zapkey_db1"

# ─── DB2 (External Read-Only PostgreSQL) ─────────────────────
DB2_URL="postgresql://postgres:password@localhost:5432/zapkey_db2"

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-min-32-chars"
JWT_EXPIRES_IN="7d"

# ─── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"

# ─── App ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
